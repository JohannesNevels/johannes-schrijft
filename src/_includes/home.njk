---
layout: base.njk
pageTitle: "versregel — gedichten van johannes"
---
<article class="poem poem--home">
  <h1 class="home-question">alles goed?</h1>
  <hr class="rule" />
  <div class="poem__body">
    {{ content | safe }}
  </div>
  <hr class="rule" />
</article>

{%- if collections.recent.length %}
<nav class="recent" aria-label="Nieuwe gedichten">
  <p class="recent__label">nieuwe gedichten</p>
  <ul class="recent__list">
    {%- for gedicht in collections.recent %}
    {%- if loop.index <= 5 %}
    <li class="recent__item">
      <a class="recent__link" href="{{ gedicht.url | url }}">{{ gedicht.data.title }}</a>
      <span class="recent__date">{{ gedicht.date | datum }}</span>
    </li>
    {%- endif %}
    {%- endfor %}
  </ul>
  <p class="recent__all"><a href="{{ '/gedichten/' | url }}">alle gedichten →</a></p>
</nav>
{%- endif %}
