---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.lang }}">
  <title>{{ site.name }}</title>
  <subtitle>{{ site.tagline }}</subtitle>
  <link href="{{ site.url }}{{ '/feed.xml' | url }}" rel="self"/>
  <link href="{{ site.url }}{{ '/' | url }}"/>
  <updated>{{ collections.gedichten | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ site.url }}{{ '/' | url }}</id>
  <author>
    <name>{{ site.author }}</name>
  </author>
  {%- for gedicht in collections.gedichten | reverse %}
  {%- set absUrl = site.url + (gedicht.url | url) %}
  <entry>
    <title>{{ gedicht.data.title }}</title>
    <link href="{{ absUrl }}"/>
    <updated>{{ gedicht.date | dateToRfc3339 }}</updated>
    <id>{{ absUrl }}</id>
    <content type="html">{{ gedicht.templateContent }}</content>
  </entry>
  {%- endfor %}
</feed>
